{
  "expo": {
    "name": "Kribb",
    "slug": "kribb",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/kribb-icon.png",
    "scheme": "kribb",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.mwstudio.kribb",
      "appleTeamId": "BA6Y63VR6W",
      "icon": {
        "light": "./assets/images/kribb-icon.png",
        "dark": "./assets/images/kribb-icon.png"
      }
    },
    "android": {
      "package": "com.mwstudio.kribb",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-location",
        {
          "locationWhenInUse": "Allow Kribb to access your location while using the app"
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/kribb.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      [
        "@clerk/expo",
        {
          "appleSignIn": false
        }
      ],
      "expo-secure-store",
      "expo-image-picker"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
